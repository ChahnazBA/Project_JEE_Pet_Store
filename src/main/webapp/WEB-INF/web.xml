<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">
    <welcome-file-list>
        <welcome-file>inscription.jsp</welcome-file>
    </welcome-file-list>

    <servlet>
        <servlet-name>InscriptionServlet</servlet-name>
        <servlet-class>Controller.InscriptionServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>InscriptionServlet</servlet-name>
        <url-pattern>/InscriptionServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>PetServlet</servlet-name>
        <servlet-class>Controller.PetServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PetServlet</servlet-name>
        <url-pattern>/PetServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>PetSuppServlet</servlet-name>
        <servlet-class>Controller.PetSuppServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PetSuppServlet</servlet-name>
        <url-pattern>/PetSuppServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DemandeServlet</servlet-name>
        <servlet-class>Controller.DemandeServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DemandeServlet</servlet-name>
        <url-pattern>/DemandeServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DetailsServlet</servlet-name>
        <servlet-class>Controller.DetailsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DetailsServlet</servlet-name>
        <url-pattern>/DetailsServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdoptionServlet</servlet-name>
        <servlet-class>Controller.AdoptionServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdoptionServlet</servlet-name>
        <url-pattern>/AdoptionServlet</url-pattern>
    </servlet-mapping>
</web-app>